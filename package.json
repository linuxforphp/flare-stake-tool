    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.26.0",
    "@flarenetwork/eslint-config-flare": "^0.0.2",
    "@flarenetwork/prettier-config-flare": "^0.0.3",
    "@types/clear": "^0.1.2",
    "@types/elliptic": "^6.4.15",
    "@types/figlet": "^1.5.6",
    "@types/inquirer": "9.0.3",
