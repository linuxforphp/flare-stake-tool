    "@ledgerhq/hw-app-eth": "^6.42.0",
    "@ledgerhq/hw-transport-node-hid": "^6.29.5",
    "@ledgerhq/hw-transport-webhid": "^6.29.4",
    "@metamask/detect-provider": "^2.0.0",
