    "@mui/x-data-grid": "^6.20.4",
    "@trezor/connect-web": "^9.4.5",
    "@zondax/ledger-flare": "^1.1.0",
    "bech32": "^2.0.0",
    "bn.js": "^5.2.1",
    "buffer": "^6.0.3",
    "chalk": "^4.1.2",
    "clear": "^0.1.0",
