{
  "compilerOptions": {
    // File Layout
    "rootDir": "./",
    "outDir": "dist",

    // Environment Settings
    "target": "ES2024",
    "module": "CommonJS",
    "lib": ["ES2024", "DOM"],
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,

    // Stricter Typechecking Options
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,

    // Compatibility
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "preserveSymlinks": true
  },
  "exclude": ["node_modules", "scripts", "test", "dist"]
}
